{
  "name": "T2.3-2xh264-4k-plus-720p-camera",
  "description": "2x H.264: composited HLS at 4K @ 18Mbps plus raw H.264 720p camera @ 12Mbps. Failure mode 3 analogue — expected to back-pressure (dropped frames, stretched segments) but NOT deadlock the Mac. If it deadlocks instead of degrading, that is a new data point about the H.264 engine's behaviour at extreme combined bitrate.",
  "tier": "tier-2",
  "durationSeconds": 30,
  "watchdogGraceSeconds": 10,
  "frameRate": 30,
  "expected": "degraded",
  "source": {
    "kind": "synthetic-screen",
    "width": 3840,
    "height": 2160,
    "pattern": "moving",
    "colorSpace": "srgb",
    "additional": [
      {
        "kind": "synthetic-camera",
        "width": 1280,
        "height": 720,
        "pattern": "moving",
        "colorSpace": "rec709"
      }
    ]
  },
  "compositor": {
    "outputWidth": 3840,
    "outputHeight": 2160,
    "includeCameraOverlay": true,
    "useLanczosScaling": true,
    "renderMode": "render-to-bounds"
  },
  "writers": [
    {
      "kind": "composited-hls",
      "name": "screen-hls-4k",
      "width": 3840,
      "height": 2160,
      "bitrate": 18000000
    },
    {
      "kind": "raw-h264",
      "name": "camera-720p",
      "width": 1280,
      "height": 720,
      "bitrate": 12000000
    }
  ]
}
