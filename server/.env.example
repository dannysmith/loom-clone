# Copy to .env (gitignored) and edit as needed.
# Bun auto-loads .env on `bun run dev`.

# Server bind. Default is loopback-only — change HOST to 0.0.0.0 only when
# fronted by HTTPS termination. Bearer tokens
# over plain HTTP on the open internet are trivially interceptable.
HOST=127.0.0.1
PORT=3000

# Public-facing base URL used for absolute URLs in API responses (clipboard,
# complete endpoint). If unset, constructed from HOST + PORT.
# PUBLIC_URL=https://v.danny.is

# BunnyCDN cache purging. When set, the server purges CDN-cached content on
# video state changes (visibility, trash, slug rename, thumbnail, etc.).
# Get your API key from https://dash.bunny.net/account/settings → API Keys.
# BUNNY_CDN_API_KEY=

# Admin authentication. When ADMIN_PASSWORD is set, all /admin/* routes
# require login. SESSION_SECRET must also be set (used to sign session
# cookies). Locally (NODE_ENV unset) you can leave both unset to skip
# auth while iterating. In production (NODE_ENV=production, set by
# docker-compose.prod.yml) the server refuses to start unless
# ADMIN_PASSWORD is set.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# SESSION_SECRET=           # generate with: openssl rand -base64 48
